# Immich server URL (no trailing slash)
# Do NOT include /api at the end — the script adds it automatically
IMMICH_URL=http://localhost:2283

# API key from: Immich Web UI → Account Settings → API Keys
IMMICH_API_KEY=your_api_key_here

# Path prefix to match trashed assets
# Must match the beginning of the originalPath stored in Immich
# Example: /mnt/nas/photos/old-folder/
PATH_PREFIX=/your/external/library/path/

# Dry run mode — set to false only after verifying the dry-run output
DRY_RUN=true

# How many assets to process per API batch (max 100)
BATCH_SIZE=100
